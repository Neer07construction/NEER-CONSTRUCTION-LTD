# ════════════════════════════════════════════════
#  NEER CONSTRUCTION LTD — WhatsApp Bot Config
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── WhatsApp (from Meta Developer Console) ───────
# Go to: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=your_whatsapp_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here

# ── Webhook Verification ─────────────────────────
# Make up any string — use the same one in Meta console
VERIFY_TOKEN=NeerBotSecret2024

# ── Claude AI (from console.anthropic.com) ───────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Server Port (optional, default 3000) ─────────
PORT=3000
